# Hermes Dashboard Environment Variables

# API key for dashboard authentication (also used as HMAC signing secret)
DASHBOARD_API_KEY=hermes-dashboard-2026

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Hermes home directory (where config.yaml, state.db, cron/, memory/, skills/ live)
HERMES_HOME=/root/.hermes

# Obsidian vault path
OBSIDIAN_VAULT=/root/obsidian-vault

# VansRoute API key (for provider health endpoints)
VANSROUTE_API_KEY=your-vansroute-key-here

# Backend URL (used by frontend container to reach backend)
BACKEND_URL=http://backend:8000
